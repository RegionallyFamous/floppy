{
  "name": "regionallyfamous/floppy",
  "description": "Freedom for your files: a WordPress-owned private file system with Finder-native sync.",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "require": {},
  "require-dev": {
    "phpunit/phpunit": "^9.6",
    "yoast/phpunit-polyfills": "^2.0"
  },
  "scripts": {
    "lint": "find floppy -name '*.php' -not -path '*/vendor/*' -print0 | xargs -0 -n1 php -l",
    "test": "phpunit -c phpunit.xml.dist"
  },
  "config": {
    "allow-plugins": false,
    "platform": {
      "php": "8.1.34"
    },
    "sort-packages": true
  }
}
